{
  "name": "logistics-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:mobile": "npm run dev --workspace=apps/mobile",
    "build": "npm run build --workspaces",
    "build:prod": "npm run build --workspace=apps/web && npm run build --workspace=apps/api",
    "start:prod": "node apps/api/dist/index.js"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  },
  "dependencies": {
    "expo": "~54.0.35"
  }
}
