# PostgreSQL connection string — provided automatically by Railway when you add a Postgres database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port the API listens on — Railway sets this automatically, no need to change
PORT=3001

# Shared login password. When set, the web app requires this password to sign in.
# Leave unset for local development to skip login (the API logs a warning).
AUTH_PASSWORD=

# Optional: secret used to sign session cookies. If unset, one is derived from
# AUTH_PASSWORD. Set an explicit random value in production so existing sessions
# survive a password change.
AUTH_SECRET=
